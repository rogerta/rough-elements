---
import fs from 'node:fs';

// Read the manifest generated by the CEM analyzer
const manifestRaw = fs.readFileSync('./custom-elements.json', 'utf-8');
const manifest = JSON.parse(manifestRaw);
---

{manifest.modules.map((mod) => {
  const customElements = mod.declarations?.filter((dec) => dec.customElement) || [];
  
  return customElements.map((el) => (
    <section class="component-doc">
      <h2>&lt;{el.tagName}&gt;</h2>
      <p>{el.description || 'No description provided.'}</p>

      {/* Attributes Table */}
      {el.attributes?.length > 0 && (
        <h3>Attributes</h3>
        <table>
          <thead>
            <tr><th>Name</th><th>Type</th><th>Default</th><th>Description</th></tr>
          </thead>
          <tbody>
            {el.attributes.map((attr) => (
              <tr>
                <td><code>{attr.name}</code></td>
                <td><code>{attr.type?.text || 'string'}</code></td>
                <td><code>{attr.default || '-'}</code></td>
                <td>{attr.description || ''}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}

      {/* Slots List */}
      {el.slots?.length > 0 && (
        <h3>Slots</h3>
        <ul>
          {el.slots.map((slot) => (
            <li><strong>{slot.name || 'default'}</strong>: {slot.description || ''}</li>
          ))}
        </ul>
      )}
      <hr />
    </section>
  ));
})}

