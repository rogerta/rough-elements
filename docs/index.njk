<!doctype html>
<html>
<head>
<title>Rough Elements</title>
</head>
<body>
{% for clazz in components %}
  <h1>{{clazz.tagName}}</h1>
  <h2>Slots</h2>
    <table>
      <tr><th>Name</th><th>Description</th></tr>
      {% for slot in clazz.slots %}
      <tr><td>{{slot.name | d('[default]', '[default]')}}</td><td>{{slot.description}}</td></tr>
      {% endfor %}
    </table>
  <h2>Properties</h2>
  <h2>Events</h2>
  <h2>Methods</h2>
  <h2>Parts</h2>
{% endfor %}
</body>
</html>

