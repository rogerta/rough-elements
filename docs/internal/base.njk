<!doctype html>
<html>
<head>
<title>Rough Elements</title>
<meta name="color-scheme" content="light dark"/>

<link rel="icon" type="image/svg+xml" href="/img/favicon.svg">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,100..900;1,100..900&family=Noto+Serif:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">

<link rel="stylesheet" media="screen"
    href="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.11.1/build/styles/atom-one-light.min.css">
<link rel="stylesheet" media="screen and (prefers-color-scheme: dark)"
    href="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.11.1/build/styles/atom-one-dark.min.css">
<script src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.11.1/build/highlight.min.js"></script>

<link href="/css/base.css" rel="stylesheet">
<style>
body {
  margin: 0;
  padding: 0;
  font-family: "Noto Sans", sans-serif;
  font-optical-sizing: auto;
  font-weight: 400;
  font-style: normal;
  font-variation-settings: "wdth" 100;
}
#maingrid {
  display: grid;
  grid-template-columns: auto 1fr;
  height: 100vh;
}
aside {
  padding: 2rem;
  border-right: 1px solid rgb( 0 0 0 / 0.3);
  overflow: auto;
}
aside header {
  margin-bottom: 1rem;
}
aside ul {
  list-style-type: none;
  padding: 0;
  margin: 0;
}
aside ul li {
  margin-bottom: 0.5rem;
}
li ul {
  margin-left: 1rem;
}
aside h3 {
  margin-bottom: 0.5rem;
}
aside h3+ul {
  padding-left: 1rem;
}
main {
  padding: 0 2rem 2rem 2rem;
  overflow: auto;
}
aside header img {
  width: 16rem;
}
/* This filter generated using:
 * https://angel-rs.github.io/css-color-filter-generator/ */
img.logo {
  filter: brightness(0) saturate(100%) invert(20%) sepia(26%) saturate(3077%)
          hue-rotate(198deg) brightness(99%) contrast(88%);;
}
{% block style %}{% endblock %}
</style>
</head>
<body>
<div id="maingrid">
  <aside>
    <header>
      <a href="/"><img class="logo" src="/img/rough-elements.svg"/></a>
    </header>
    <nav>
      <ul>
        <li>
          <h3>Getting Started</h3>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/bordersandbackgrounds">Borders & Backgrounds</a></li>
            <li><a href="/handlingforms">Handling Forms</a></li>
            <li><a href="/userdefinedicons">User Defined Icons</a></li>
            <li><a href="/themes">Themes</a></li>
            <li>Examples</li>
            <li>
              <ul>
                <li><a href="/exsearch" target="_blank">Rough Search</a> &#x2197;</li>
                <li>Rough Mail &#x2197;</li>
                <li>Rough Comms &#x2197;</li>
              </ul>
            </li>
          </ul>
        </li>
        <li>
          <h3>Components</h3>
          <ul>
          {% for clazz in components %}
            <li><a href="/component/{{clazz.tagName}}">{{clazz.tagName | replace('re-', '') | replace('-', ' ') | title}}</a></lis>
          {% endfor %}
          </ul>
        </li>
      </ul>
    </nav>
  </aside>
  <main>
    {% block main %}{% endblock %}
  </main>
</div>
<script>
// Reduce the number of languages highlight.js should consider to improve
// correct language detection.  Otherwise small snippets of html are ofen
// confused for perl or bash.
hljs.configure({languages: ['html', 'css', 'javascript']});
hljs.highlightAll();
</script>
</body>
</html>
