---
pagination:
  data: components
  size: 1
  alias: c
permalink: "component/{{ c.tagName | slugify }}/"
---
{% extends "./internal/base.njk" %}

{% block style %}
.classnametitle {
  opacity: 0.4;
  font-size: 0.8em;
}
h1 {
  position: sticky;
  top: 0;
  background: Canvas;
  padding: 3rem 0 1rem 0;
  margin: 0;
}
h2 {
  border-top: 1px solid rgb(0 0 0 / 0.2);
  padding-top: 0.5rem;
  margin-top: 2rem;
}
table {
  border-collapse: collapse;
}
tbody tr:nth-child(even) {
  background-color: rgb(0 0 0 / 0.05);
}
td, th {
  text-align: start;
  padding: 0.5rem 1rem;
  w
}
code {
  color: rgb(40 66 131);
  font-weight: bold;
  font-size: 1.2em;
  text-wrap: nowrap;
}
.slot-name,
.part-name,
.property-name,
.property-type,
.property-params {
  font-family: monospace;
  text-wrap: nowrap;
}
{% endblock %}

{% block main %}
<h1>{{c.tagName | replace('re-', '') | replace('-', ' ') | title}} <span class="classnametitle">{{c.tagName}}</span></h1>
{{c.description | marked | safe }}

<h2>Slots</h2>
  <table>
  <thead>
    <tr><th>Name</th><th>Description</th></tr>
  </thead>
  <tbody>
    {% for slot in c.slots %}
    <tr>
      <td class="slot-name">{{slot.name | d('[default]', true)}}</td>
      <td>{{slot.description | marked | safe }}</td>
    </tr>
    {% endfor %}
  </tbody>
  </table>

<h2>Properties</h2>
  <table>
  <thead>
    <tr><th>Name</th><th>Description</th><th>Reflects</th><th>Type</th></tr>
  </thead>
  <tbody>
  {% for m in c.members %}
    {# Don't bother documenting private and protected fields. Also, don't
       bother documenting the 'styles' field since it's Lit's internal CSS
       styling of the element. #}
    {% if m.privacy != 'private' and m.privacy != 'protected' and
        m.kind == 'field' and m.name != 'styles' and
        m.inheritedFrom == undefined %}
    <tr>
      <td class="property-name">{{m.name}}</td>
      <td>{{m.description | marked | safe }}</td>
      <td>{{'true' if m.reflects else ''}}</td>
      <td class="property-type">{{m.type.text}}</td>
    </tr>
    {% endif %}
  {% endfor %}
  </tbody>
  </table>

<h2>CSS Properties</h2>
  <table>
  <thead>
    <tr><th>Name</th><th>Description</th></tr>
  </thead>
  <tbody>
    {% for part in c.cssProperties %}
      {% if part.inheritedFrom == undefined %}
      <tr>
        <td class="property-name">{{part.name }}</td>
        <td>{{part.description | marked | safe }}</td>
      </tr>
      {% endif %}
    {% endfor %}
  </tbody>
  </table>

<h2>Events</h2>

<h2>Methods</h2>
  <table>
  <thead>
    <tr><th>Name</th><th>Description</th><th>Arguments</th></tr>
  </thead>
  <tbody>
  {% for m in c.members %}
    {# Don't bother documenting private, protected, or inherited methods. #}
    {% if m.privacy != 'private' and m.privacy != 'protected' and
       m.kind == 'method' and m.inheritedFrom == undefined and
       m.name != 'handleEvent' %}
    <tr>
      <td class="property-name">{{m.name}}</td>
      <td>{{m.description | marked | safe }}</td>
      <td class="property-params">({{m.parameters | mapParam() | join(', ')}})</td>
    </tr>
    {% endif %}
  {% endfor %}
  </tbody>
  </table>

<h2>Parts</h2>
  <table>
  <thead>
    <tr><th>Name</th><th>Description</th></tr>
  </thead>
  <tbody>
    {% for part in c.cssParts %}
      {% if true %}
      <tr>
        <td class="part-name">{{part.name | d('[default]', '[default]')}}</td>
        <td>{{part.description | marked | safe }}</td>
      </tr>
      {% endif %}
    {% endfor %}
  </tbody>
  </table>
{% endblock %}
