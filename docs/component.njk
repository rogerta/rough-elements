---
pagination:
  data: components
  size: 1
  alias: c
permalink: "component/{{ c.tagName | slugify }}/"
---
{% extends "./internal/base.njk" %}

{% block style %}
.classnametitle {
  opacity: 0.4;
  font-size: 0.8em;
}
h1 {
  position: sticky;
  top: 0;
  background: Canvas;
  padding: 3rem 0 1rem 0;
  margin: 0;
}
h2 {
  border-top: 1px solid rgb(0 0 0 / 0.2);
  padding-top: 0.5rem;
  margin-top: 2rem;
}
table {
  border-collapse: collapse;
}
tbody tr:nth-child(even) {
  background-color: rgb(0 0 0 / 0.05);
}
td, th {
  text-align: start;
  padding: 0 1rem;
}
code {
  color: rgb(40 66 131);
  font-weight: bold;
  font-size: 1.2em;
  text-wrap: nowrap;
}
.slot-name,
.part-name,
.property-default,
.property-name,
.property-params,
.property-type {
  font-family: monospace;
  text-wrap: nowrap;
}
{% endblock %}

{% block main %}
<h1>{{c.tagName | replace('re-', '') | replace('-', ' ') | title}} <span class="classnametitle">{{c.tagName}}</span></h1>
{{c.description | marked | safe }}

<h2>Slots</h2>
  <table>
  <thead>
    <tr><th>Name</th><th>Description</th></tr>
  </thead>
  <tbody>
    {% for slot in c.slots %}
    <tr>
      <td class="slot-name">{{slot.name | d('[default]', true)}}</td>
      <td>{{slot.description | marked | safe }}</td>
    </tr>
    {% endfor %}
  </tbody>
  </table>

<h2>Properties</h2>
  {% set properties = c | filterForProperties %}
  {% if properties | length %}
    <table>
    <thead>
      <tr><th>Name</th><th>Description</th><th>Reflects</th><th>Type</th><th>Default</th></tr>
    </thead>
    <tbody>
    {% for m in properties %}
    <tr>
      <td class="property-name">{{m.name}}</td>
      <td>{{m.description | marked | safe }}</td>
      <td>{{'true' if m.reflects else ''}}</td>
      <td class="property-type">{{m.type.text}}</td>
      <td class="property-default">{{m.default | d('', true) }}</td>
    </tr>
    {% endfor %}
    </tbody>
    </table>
  {% else %}
    No properties.
  {% endif %}

<h2>CSS Properties</h2>
  {% set cssProperties = c | filterForCSSProperties %}
  {% if cssProperties | length %}
    <table>
    <thead>
      <tr><th>Name</th><th>Description</th></tr>
    </thead>
    <tbody>
      {% for prop in cssProperties %}
      <tr>
        <td class="property-name">{{prop.name }}</td>
        <td>{{prop.description | marked | safe }}</td>
      </tr>
      {% endfor %}
    </tbody>
    </table>
  {% else %}
    No CSS properties.
  {% endif %}

<h2>Events</h2>
No events.

<h2>Methods</h2>
  {% set methods = c | filterForMethods %}
  {% if methods | length %}
    <table>
    <thead>
      <tr><th>Name</th><th>Description</th><th>Arguments</th></tr>
    </thead>
    <tbody>
    {% for m in methods %}
    <tr>
      <td class="property-name">{{m.name}}</td>
      <td>{{m.description | marked | safe }}</td>
      <td class="property-params">({{m.parameters | mapParam() | join(', ')}})</td>
    </tr>
    {% endfor %}
    </tbody>
    </table>
  {% else %}
    No methods.
  {% endif %}

<h2>Parts</h2>
  {% set parts = c | filterForParts %}
  {% if parts | length %}
    <table>
    <thead>
      <tr><th>Name</th><th>Description</th></tr>
    </thead>
    <tbody>
      {% for part in parts %}
      <tr>
        <td class="part-name">{{part.name | d('[default]', true)}}</td>
        <td>{{part.description | marked | safe }}</td>
      </tr>
      {% endfor %}
    </tbody>
    </table>
  {% else %}
    No parts.
  {% endif %}

  {% endblock %}
