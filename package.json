{
  "name": "rough-elements",
  "description": "Collection of hand-drawn sketchy web components",
  "version": "3.0.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/rough-elements.umd.cjs",
  "module": "./dist/rough-elements.js",
  "exports": {
    ".": {
      "import": "./dist/rough-elements.js",
      "require": "./dist/rough-elements.umd.cjs"
    }
  },
  "scripts": {
    "cem": "cem analyze --dev",
    "docs:start": "astro dev",
    "docs:build": "astro build",
    "docs:preview": "astro preview",
    "dev": "vite",
    "build": "vite build && tsc",
    "preview": "vite preview"
  },
  "keywords": [
    "webcomponent",
    "web component",
    "rough",
    "sketchy",
    "hand-drawn",
    "hand drawn",
    "wireframe"
  ],
  "author": "Roger Tawa <roger@tawacentral.net>",
  "originalAuthor": "Preet Shihn <preetshihn@gmail.com>",
  "contributors": [
    "Preet Shihn <preetshihn@gmail.com>"
  ],
  "license": "MIT",
  "dependencies": {
    "@rogerta/roughjs": "5.1.0",
    "lit": "3.3.2"
  },
  "devDependencies": {
    "@astrojs/starlight": "^0.39.2",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "astro": "^6.3.7",
    "htmlparser2": "^12.0.0",
    "typescript": "6.0.3",
    "vite": "8.0.11",
    "web-component-analyzer": "^2.0.0"
  },
  "customElements": "custom-elements.json"
}
